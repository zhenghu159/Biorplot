type <- 'Gr'
result <- type_links(type)
unique(result[[1]]$source)
source.order <- unique(result[[1]]$source)
Nodes.order <- c(source.order, target.order)
source.colour <- c(pal_d3("category20", alpha = 0.7)(20),pal_rickandmorty("schwifty", alpha = 0.6)(4))
Nodes.colour <- c(source.colour,target.colour)
p_links <- Bior_Sankey(result[[1]], Nodes.order = Nodes.order, Nodes.colour = Nodes.colour, fontSize=20)
saveNetwork(p_links,paste(type,'/','observed/',type,'_observed.html',sep=''))
p_links_norm <- Bior_Sankey(result[[2]], Nodes.order = Nodes.order, Nodes.colour = Nodes.colour, fontSize=20)
saveNetwork(p_links_norm,paste(type,'/','norm/',type,'_norm.html',sep=''))
cluster <- c('L2-3-Cux2','L5-Deptor','L5-Tshz2','L5-Pou3f1','L6-Oprk1','L6-Syt6')
for (i in 1:6){
p_links_cluster <- Bior_Sankey(result[[3]][[i]], Nodes.order = Nodes.order, Nodes.colour = Nodes.colour, fontSize=20)
saveNetwork(p_links_cluster,paste(type,'/','observed_cluster/',type,'_observed_',cluster[i],'.html',sep=''))
p_links_cluster_norm <- Bior_Sankey(result[[4]][[i]], Nodes.order = Nodes.order, Nodes.colour = Nodes.colour, fontSize=20)
saveNetwork(p_links_cluster_norm,paste(type,'/','norm_cluster/',type,'_norm_',cluster[i],'.html',sep=''))
}
