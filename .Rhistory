library(Seurat)
# -----------------------------------------------------------------------------------------------------
raw_data <- read.csv("barcode_exp.csv", header = T,row.names = 1)
#write.csv(rownames(raw_data),file='cell.csv')
data <- as.data.frame(t(raw_data))
rownames(data) <- gsub("X","",rownames(data))
data[1:5,1:5]
dim(data) # 23337 2357
seuratobject <- CreateSeuratObject(counts = data, min.cells = 3)
seuratobject[["percent.mt"]] <- PercentageFeatureSet(seuratobject, pattern = "^mt.")
#
seuratobject <- NormalizeData(seuratobject)
seuratobject <- FindVariableFeatures(seuratobject, selection.method = "vst", nfeatures = 2000)
all.genes <- rownames(seuratobject)
seuratobject <- ScaleData(seuratobject,features = all.genes)
seuratobject <- RunPCA(seuratobject,features = VariableFeatures(object = seuratobject))
#
seuratobject <- FindNeighbors(seuratobject, dims = 1:10)
seuratobject <- FindClusters(seuratobject, resolution = 1)
seuratobject <- RunUMAP(seuratobject, dims = 1:10, label = T)
DimPlot(seuratobject, reduction = "umap",label=T)
save.image('barcode细胞分析.RData')
# ----------------------------------------------------------------------------------------------
# 自定义聚类
cluster_data <- read.csv('output/barcode_kmeans.csv',header = T,row.names = 1)
new.ident <- cluster_data$Cluster[match(names(seuratobject@active.ident),rownames(cluster_data))]
names(new.ident) <- names(seuratobject@active.ident)
new.ident <- as.factor(new.ident)
seuratobject@active.ident <- new.ident
DimPlot(seuratobject, reduction = "umap",label=T)
# 合并为两类----------------------------------------------------------------------------------------------
levels(seuratobject)
new.cluster.ids <- c('Type1',rep('Type2',6))
names(new.cluster.ids) <- levels(seuratobject)
test_seuratobject <- RenameIdents(seuratobject, new.cluster.ids)
DimPlot(test_seuratobject, reduction = "umap",label = TRUE)
test_seuratobject.markers <- FindMarkers(test_seuratobject,ident.1 = "Type1", "Type2")
head(test_seuratobject.markers)
?FindMarkers
test_seuratobject.markers <- FindMarkers(test_seuratobject,ident.1 = "Type1", ident.2 = "Type2", logfc.threshold = 0)
test_seuratobject.markers <- FindMarkers(test_seuratobject,ident.1 = "Type1", ident.2 = "Type2", logfc.threshold = 0.1)
write.csv(test_seuratobject.markers,file = '差异分析_分两类/Type1_VS_Type2_diff_gene.csv')
write.csv(test_seuratobject.markers,file = '差异分析_分两类/Type1_VS_Type2_diff_gene.csv')
head(test_seuratobject.markers)
DEG_gene <- test_seuratobject.markers[which(abs(test_seuratobject.markers$avg_log2FC)>1 &
(test_seuratobject.markers$p_val_adj < 0.01)),]
nrow(DEG_gene)
DEG_gene <- test_seuratobject.markers[which(abs(test_seuratobject.markers$avg_log2FC)>0.5 &
(test_seuratobject.markers$p_val_adj < 0.01)),]
nrow(DEG_gene)
DEG_gene <- DEG_gene[order(DEG_gene$avg_log2FC,decreasing = T),]
exprs <- data.frame(FetchData(object = test_seuratobject, vars = rownames(DEG_gene), slot = "data"))
exprs <- exprs[match(rownames(cluster_data),rownames(exprs)),]
write.csv(exprs,file = '差异分析_分两类/Type1_VS_Type2_DEG_exp.csv')
