# 2 Basic Plot =================================================================
# 2.1 Bior_Sankey --------------------------------------------------------------
# links data, colnames must have 'source' 'target' 'value'
links <- data.frame(
source=c("C","A", "B", "E", "D"),
target=c("b","c", "a", "e", "d"),
value=c(1, 2, 0, 4, 5)
)
links
links <- links[which(links$value != 0),]
links
links[which(links$value != 0),]
is.null(NULL)
!is.null(NULL)
nodes <- data.frame(name=unique(c(links$source, links$target)))
nodes
# Set Nodes order and colour
Nodes.order <- c("A", "B", "C", "D", "E", "a", "b", "c", "d", "e")
Nodes.order[which(Nodes.order %in% nodes)]
nodes <- unique(c(links$source, links$target))
nodes
nodes <- Nodes.order[which(Nodes.order %in% nodes)]
nodes
nodes <- data.frame(name=nodes)
nodes
nodes <- data.frame(name=nodes)
nodes
nodes$index <- 0:(nrow(nodes) - 1)
links <- merge(links, nodes, by.x="source", by.y="name")
links <- merge(links, nodes, by.x="target", by.y="name")
names(links) <- c("target","source","Value","IDsource","IDtarget")
links
source('Biorplot.R')
# 2 Basic Plot =================================================================
# 2.1 Bior_Sankey --------------------------------------------------------------
# links data, colnames must have 'source' 'target' 'value'
links <- data.frame(
source=c("C","A", "B", "E", "D"),
target=c("b","c", "a", "e", "d"),
value=c(1, 2, 0, 4, 5)
)
# Set Nodes order and colour
Nodes.order <- c("A", "B", "C", "D", "E", "a", "b", "c", "d", "e")
Nodes.colour <- pal_d3("category20", alpha = 0.7)(20)
p <- Bior_Sankey(links, Nodes.order=Nodes.order, Nodes.colour=Nodes.colour, fontSize=20)
source('Biorplot.R')
