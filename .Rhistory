# 4 NGS Plot ===================================================================
# 4.1 Bior_Volcano -------------------------------------------------------------
data <- read.table('testdata/Bior_Volcano.txt', header=T)
logfc <- data$log2FoldChange
pvalue <- data$pvalue
deg.data <- data.frame(logfc=logfc,pvalue=pvalue)
deg.data$logpv <- -log10(deg.data$pvalue)
deg.data$Group <- "not significant"
deg.data$Group[which((deg.data$pvalue < pvalue.threshold) &
(deg.data$logfc > logfc.threshold.up))] <- "Up"
deg.data$Group[which((deg.data$pvalue < pvalue.threshold) &
(deg.data$logfc < logfc.threshold.Down))] <- "Down"
head(deg.data)
head(data)
gene <- data$Gene
deg.data <- data.frame(gene=gene, logfc=logfc, pvalue=pvalue)
deg.data$logpv <- -log10(deg.data$pvalue)
deg.data$Group <- "not significant"
head(deg.data)
label.gene <- c('DOK6','TBX5')
deg.data$label = ""
head(deg.data)
match(label.gene,deg.data$gene)
deg.data$label[match(label.gene,deg.data$gene)] <- label.gene
head(deg.data)
?geom_point
library(ggrepel)
source('Biorplot.R')
# 4 NGS Plot ===================================================================
# 4.1 Bior_Volcano -------------------------------------------------------------
data <- read.table('testdata/Bior_Volcano.txt', header=T)
gene <- data$Gene
logfc <- data$log2FoldChange
pvalue <- data$pvalue
label.gene <- c('DOK6','TBX5')
p <- Bior_Volcano(logfc, pvalue, title="Test Bior_Volcano", legend.position="none",
limits.x=c(-3,3),limits.y=c(0,10))
p <- Bior_Volcano(gene, logfc, pvalue, label.gene, title="Test Bior_Volcano", legend.position="none",
limits.x=c(-3,3),limits.y=c(0,10))
source('Biorplot.R')
